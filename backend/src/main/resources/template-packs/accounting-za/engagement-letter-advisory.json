      "content": [
        { "type": "text", "text": "Engagement Letter — Advisory Services" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Dear " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": "," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "We are pleased to confirm our engagement to provide advisory services in connection with " },
        { "type": "variable", "attrs": { "key": "project.name" } },
        { "type": "text", "text": ". This letter sets out the terms under which " },
        { "type": "variable", "attrs": { "key": "org.name" } },
        { "type": "text", "text": " will provide these services." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Scope of Work" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "The advisory engagement will cover the following areas as agreed:" }
      ]
    },
    {
      "type": "bulletList",
      "content": [
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Financial analysis and recommendations;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Tax planning and structuring advice;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Business process review and improvement recommendations;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Ad hoc consultations as requested by the client." }] }] }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Fee Basis" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Services will be charged on a time and materials basis at the agreed hourly rate. Time will be recorded in six-minute increments. An estimate of anticipated hours will be provided prior to commencement, but actual fees may vary depending on the complexity and scope of work required." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Limitations" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Our advisory services are based on the information provided to us and the legislation in force at the time of the engagement. We do not accept responsibility for losses arising from changes in legislation or from information that is incomplete or inaccurate." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Acceptance" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Please confirm your acceptance of the terms set out in this engagement letter by signing and returning a copy to our offices." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Terms and Conditions" }
      ]
    },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-limitation-of-liability" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-termination" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-confidentiality" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-third-party-reliance" } },
