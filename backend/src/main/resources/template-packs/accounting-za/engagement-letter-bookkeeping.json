{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": { "level": 1 },
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 2 },
      "content": [
        { "type": "text", "text": "Engagement Letter — Monthly Bookkeeping Services" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Dear " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": "," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "We are pleased to confirm our engagement to provide monthly bookkeeping services as outlined below. This letter sets out the terms and conditions under which " },
        { "type": "variable", "attrs": { "key": "org.name" } },
        { "type": "text", "text": " will render services to your organisation." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Client Details" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Client:" },
        { "type": "text", "text": " " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "conditionalBlock",
      "attrs": {
        "fieldKey": "customer.customFields.acct_company_registration_number",
        "operator": "isNotEmpty"
      },
      "content": [
        {
          "type": "paragraph",
          "content": [
            { "type": "text", "marks": [{ "type": "bold" }], "text": "Registration Number:" },
            { "type": "text", "text": " " },
            { "type": "variable", "attrs": { "key": "customer.customFields.acct_company_registration_number" } }
          ]
        }
      ]
    },
    {
      "type": "conditionalBlock",
      "attrs": {
        "fieldKey": "project.customFields.engagement_type",
        "operator": "isNotEmpty"
      },
      "content": [
        {
          "type": "paragraph",
          "content": [
            { "type": "text", "marks": [{ "type": "bold" }], "text": "Engagement Type:" },
            { "type": "text", "text": " " },
            { "type": "variable", "attrs": { "key": "project.customFields.engagement_type" } }
          ]
        }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Scope of Work" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "The scope of our engagement includes the following monthly bookkeeping services:" }
      ]
    },
    {
      "type": "bulletList",
      "content": [
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Processing of all financial transactions into the accounting system;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Bank reconciliations for all accounts;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Preparation of monthly management accounts (income statement, balance sheet, and cash flow);" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "VAT calculations and preparation of bi-monthly VAT201 returns;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Payroll processing and submission of EMP201 returns;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Creditors and debtors management;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Fixed asset register maintenance." }] }] }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Client Responsibilities" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "To enable us to fulfil our obligations, " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": " undertakes to provide all source documents (bank statements, invoices, receipts) by the 5th business day of each month." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Acceptance" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Please confirm your acceptance of the terms set out in this engagement letter by signing and returning a copy to our offices." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Terms and Conditions" }
      ]
    },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-limitation-of-liability" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-fee-escalation" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-termination" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-confidentiality" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-document-retention" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-third-party-reliance" } },
    { "type": "clauseBlock", "attrs": { "slug": "accounting-za-electronic-consent" } },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Yours faithfully," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.documentFooterText" } }
      ]
    }
  ]
}
