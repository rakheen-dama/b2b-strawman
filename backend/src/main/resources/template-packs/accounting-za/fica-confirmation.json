{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": { "level": 1 },
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 2 },
      "content": [
        { "type": "text", "text": "FICA Confirmation Letter" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Dear " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": "," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "This letter confirms that " },
        { "type": "variable", "attrs": { "key": "org.name" } },
        { "type": "text", "text": " has completed the client identification and verification process in terms of the Financial Intelligence Centre Act 38 of 2001 (FICA) for " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": "." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Verification Details" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Client:" },
        { "type": "text", "text": " " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "conditionalBlock",
      "attrs": {
        "fieldKey": "customer.customFields.fica_verification_date",
        "operator": "isNotEmpty"
      },
      "content": [
        {
          "type": "paragraph",
          "content": [
            { "type": "text", "marks": [{ "type": "bold" }], "text": "Verification Date:" },
            { "type": "text", "text": " " },
            { "type": "variable", "attrs": { "key": "customer.customFields.fica_verification_date" } }
          ]
        }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Documents Verified" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "The following documents were obtained and verified as part of the FICA process:" }
      ]
    },
    {
      "type": "bulletList",
      "content": [
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Proof of identity (certified copy of ID document or passport);" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Proof of residential address (not older than 3 months);" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Company registration documents (where applicable);" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Tax clearance certificate or SARS registration confirmation;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Confirmation of banking details." }] }] }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "This confirmation is issued for record-keeping purposes and does not constitute legal advice or assurance regarding the client's regulatory status." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Yours faithfully," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.documentFooterText" } }
      ]
    }
  ]
}
