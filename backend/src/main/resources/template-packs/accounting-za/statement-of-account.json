{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": { "level": 1 },
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 2 },
      "content": [
        { "type": "text", "text": "Statement of Account" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Client:" },
        { "type": "text", "text": " " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Date:" },
        { "type": "text", "text": " " },
        { "type": "variable", "attrs": { "key": "generatedAt" } }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Dear " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": "," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Please find below a summary of your account. This statement reflects all invoices, payments received, and any outstanding balance as at the date of this statement." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Invoice History" }
      ]
    },
    {
      "type": "loopTable",
      "attrs": {
        "dataSource": "invoices",
        "columns": [
          { "header": "Invoice #", "key": "invoiceNumber" },
          { "header": "Date", "key": "issueDate", "format": "date" },
          { "header": "Due Date", "key": "dueDate", "format": "date" },
          { "header": "Amount", "key": "total", "format": "currency" },
          { "header": "Currency", "key": "currency" },
          { "header": "Status", "key": "status" },
          { "header": "Running Balance", "key": "runningBalance", "format": "currency" }
        ]
      }
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Total Outstanding: " },
        { "type": "variable", "attrs": { "key": "totalOutstanding" } }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Should you have any queries regarding this statement, please do not hesitate to contact our offices." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Yours faithfully," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.documentFooterText" } }
      ]
    }
  ]
}
