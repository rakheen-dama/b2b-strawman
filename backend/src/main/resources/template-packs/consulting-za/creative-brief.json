{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": { "level": 1 },
      "content": [
        { "type": "text", "text": "Creative Brief" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Client: " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Project: " },
        { "type": "variable", "attrs": { "key": "project.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Campaign type: " },
        { "type": "variable", "attrs": { "key": "project.customFields.campaign_type" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Prepared by: " },
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Schedule" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Start date: " },
        { "type": "variable", "attrs": { "key": "project.customFields.start_date" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Due date: " },
        { "type": "variable", "attrs": { "key": "project.customFields.due_date" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Background" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Provide the context for this campaign: brand position, market conditions, recent activity, and the business problem the campaign needs to solve." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Objectives" }
      ]
    },
    {
      "type": "bulletList",
      "content": [
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Primary objective (what success looks like in measurable terms)." }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Secondary objectives (supporting outcomes)." }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "KPIs and how we will measure them." }] }] }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Audience" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Describe the primary and secondary audiences: demographics, behaviours, motivations, and pain points." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Key Message & Tone" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Single-minded proposition the audience must walk away with. Note tone of voice, brand pillars, and any mandatory wording." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Deliverables" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "List the assets and channels in scope, including formats, sizes, and approval gates." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Mandatories & Constraints" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Brand assets, legal/regulatory requirements, channel limitations, and anything that must (or must not) appear." }
      ]
    },
    {
      "type": "conditionalBlock",
      "attrs": {
        "fieldKey": "project.customFields.creative_brief_url",
        "operator": "isNotEmpty"
      },
      "content": [
        {
          "type": "heading",
          "attrs": { "level": 3 },
          "content": [
            { "type": "text", "text": "Reference Material" }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            { "type": "text", "text": "Additional reference and source material is available at: " },
            { "type": "variable", "attrs": { "key": "project.customFields.creative_brief_url" } }
          ]
        }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Approvals" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "All briefs and creative work require sign-off from the client lead before the team proceeds to the next stage." }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.documentFooterText" } }
      ]
    }
  ]
}
