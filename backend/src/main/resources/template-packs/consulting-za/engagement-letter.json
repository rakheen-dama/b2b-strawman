{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": { "level": 1 },
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 2 },
      "content": [
        { "type": "text", "text": "Engagement Letter" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Dear " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": "," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "customer.addressLine1" } }
      ]
    },
    {
      "type": "conditionalBlock",
      "attrs": {
        "fieldKey": "customer.addressLine2",
        "operator": "isNotEmpty"
      },
      "content": [
        {
          "type": "paragraph",
          "content": [
            { "type": "variable", "attrs": { "key": "customer.addressLine2" } }
          ]
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "We are pleased to confirm our engagement to provide agency services in connection with " },
        { "type": "variable", "attrs": { "key": "project.name" } },
        { "type": "text", "text": ". This letter sets out the relationship between " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": " and " },
        { "type": "variable", "attrs": { "key": "org.name" } },
        { "type": "text", "text": " for the duration of the engagement." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Scope of Services" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Detailed scope, deliverables, and timelines are set out in the accompanying Statement of Work for " },
        { "type": "variable", "attrs": { "key": "project.name" } },
        { "type": "text", "text": "." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Fees & Invoicing" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Fees are quoted exclusive of VAT. " },
        { "type": "variable", "attrs": { "key": "org.name" } },
        { "type": "text", "text": " is registered for VAT under registration number " },
        { "type": "variable", "attrs": { "key": "org.taxRegistrationNumber" } },
        { "type": "text", "text": ". Invoices are due within 30 days of the invoice date unless otherwise agreed in writing." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Confidentiality & Intellectual Property" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Both parties agree to keep confidential information disclosed during the engagement strictly confidential. Intellectual property in deliverables transfers to " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": " on full payment of the related invoice, save for any pre-existing materials or third-party assets which remain with their respective owners." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Termination" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Either party may terminate this engagement on 30 days' written notice. Fees for work completed up to the termination date remain payable." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Acceptance" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Please confirm acceptance of the terms set out in this engagement letter by signing and returning a copy to our offices." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Signatures" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "For " },
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "____________________________" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Name & title" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Signed at _________________ on this _____ day of ______________ 20___." }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "For " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "____________________________" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Name & title" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Signed at _________________ on this _____ day of ______________ 20___." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Yours faithfully," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.documentFooterText" } }
      ]
    }
  ]
}
