{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": { "level": 1 },
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 2 },
      "content": [
        { "type": "text", "text": "Statement of Work" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Client: " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Project: " },
        { "type": "variable", "attrs": { "key": "project.name" } }
      ]
    },
    {
      "type": "conditionalBlock",
      "attrs": {
        "fieldKey": "project.customFields.deliverable_type",
        "operator": "isNotEmpty"
      },
      "content": [
        {
          "type": "paragraph",
          "content": [
            { "type": "text", "marks": [{ "type": "bold" }], "text": "Deliverable type: " },
            { "type": "variable", "attrs": { "key": "project.customFields.deliverable_type" } }
          ]
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Start date: " },
        { "type": "variable", "attrs": { "key": "project.startDate" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Due date: " },
        { "type": "variable", "attrs": { "key": "project.dueDate" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Scope of Work" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "This Statement of Work (SOW) sets out the services that " },
        { "type": "variable", "attrs": { "key": "org.name" } },
        { "type": "text", "text": " will deliver to " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": " in connection with " },
        { "type": "variable", "attrs": { "key": "project.name" } },
        { "type": "text", "text": "." }
      ]
    },
    {
      "type": "bulletList",
      "content": [
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Deliverables and milestones agreed in the project plan;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Acceptance criteria for each deliverable;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Roles, responsibilities, and points of contact;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Out-of-scope items and assumptions." }] }] }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Fees" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Total project budget: " },
        { "type": "variable", "attrs": { "key": "budget.amount" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Fees are exclusive of VAT and any third-party costs (production, media spend, software licences) which will be billed at cost. Invoicing follows the milestones agreed in the project plan." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Change Control" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Changes to scope, deliverables, or timeline will be raised as a written change order, estimated, and signed off before any additional work begins." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Acceptance" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "By signing below, both parties confirm acceptance of the terms set out in this Statement of Work." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Signatures" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "For " },
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "____________________________" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Name & title" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Signed at _________________ on this _____ day of ______________ 20___." }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "For " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "____________________________" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Name & title" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Signed at _________________ on this _____ day of ______________ 20___." }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.documentFooterText" } }
      ]
    }
  ]
}
