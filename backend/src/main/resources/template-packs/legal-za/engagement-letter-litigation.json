        { "type": "text", "text": " " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Matter:" },
        { "type": "text", "text": " " },
