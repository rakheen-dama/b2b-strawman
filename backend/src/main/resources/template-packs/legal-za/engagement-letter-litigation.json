    { "type": "clauseBlock", "attrs": { "slug": "legal-za-trust-deposits" } },
    { "type": "clauseBlock", "attrs": { "slug": "legal-za-termination" } },
    { "type": "clauseBlock", "attrs": { "slug": "legal-za-data-protection" } },
