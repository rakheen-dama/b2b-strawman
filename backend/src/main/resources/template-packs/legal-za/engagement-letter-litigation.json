    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "We confirm our appointment as your attorneys of record in the above matter. This letter sets out the terms and conditions under which " },
        { "type": "variable", "attrs": { "key": "org.name" } },
        { "type": "text", "text": " will render legal services to you." }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "Matter Details" }
      ]
    },
    {
