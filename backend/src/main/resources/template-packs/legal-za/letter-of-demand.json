{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": { "level": 1 },
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 2 },
      "content": [
        { "type": "text", "text": "Letter of Demand" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "WITHOUT PREJUDICE" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Dear " },
        { "type": "variable", "attrs": { "key": "customer.name" } },
        { "type": "text", "text": "," }
      ]
    },
    {
      "type": "heading",
      "attrs": { "level": 3 },
      "content": [
        { "type": "text", "text": "DEMAND FOR PAYMENT" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "We act on behalf of our client in this matter. We are instructed that you are indebted to our client in the amount as set out below." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Despite previous requests, the outstanding amount remains unpaid." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "We hereby demand that you make payment of the full outstanding amount within fourteen (14) days of receipt of this letter, failing which our client has instructed us to institute legal proceedings against you without further notice." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "In the event of legal proceedings being instituted, you will be liable for:" }
      ]
    },
    {
      "type": "bulletList",
      "content": [
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "The capital amount outstanding;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Interest thereon at the prescribed rate;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Legal costs on an attorney and client scale;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Collection commission." }] }] }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "We trust that this matter can be resolved amicably and without the need for litigation." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Yours faithfully," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.documentFooterText" } }
      ]
    }
  ]
