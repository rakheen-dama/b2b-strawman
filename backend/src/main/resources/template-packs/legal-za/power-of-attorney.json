{
  "type": "doc",
  "content": [
    {
      "type": "heading",
      "attrs": { "level": 1 },
      "content": [
        { "type": "text", "text": "Power of Attorney" }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "I/We, the undersigned," }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "marks": [{ "type": "bold" }], "text": "Name:" },
        { "type": "text", "text": " " },
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    {
      "type": "conditionalBlock",
      "attrs": {
        "fieldKey": "customer.customFields.id_passport_number",
        "operator": "isNotEmpty"
      },
      "content": [
        {
          "type": "paragraph",
          "content": [
            { "type": "text", "marks": [{ "type": "bold" }], "text": "ID / Passport Number:" },
            { "type": "text", "text": " " },
            { "type": "variable", "attrs": { "key": "customer.customFields.id_passport_number" } }
          ]
        }
      ]
    },
    {
      "type": "conditionalBlock",
      "attrs": {
        "fieldKey": "customer.customFields.physical_address",
        "operator": "isNotEmpty"
      },
      "content": [
        {
          "type": "paragraph",
          "content": [
            { "type": "text", "marks": [{ "type": "bold" }], "text": "Address:" },
            { "type": "text", "text": " " },
            { "type": "variable", "attrs": { "key": "customer.customFields.physical_address" } }
          ]
        }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "do hereby appoint and authorise" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.name" } }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "as my/our lawful attorneys and agents, with full power and authority to act on my/our behalf in all matters relating to the above instruction, and specifically to:" }
      ]
    },
    {
      "type": "bulletList",
      "content": [
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Institute, defend, or withdraw any legal proceedings on my/our behalf;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Sign all necessary documents and pleadings;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Negotiate and conclude settlements;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Brief counsel on my/our behalf;" }] }] },
        { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Do all things necessary to give effect to the above mandate." }] }] }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "This power of attorney shall remain in force until revoked in writing." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "Signed at _________________ on this _____ day of ______________ 20___." }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "text", "text": "____________________________" }
      ]
    },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "customer.name" } }
      ]
    },
    { "type": "horizontalRule" },
    {
      "type": "paragraph",
      "content": [
        { "type": "variable", "attrs": { "key": "org.documentFooterText" } }
      ]
    }
  ]
}
