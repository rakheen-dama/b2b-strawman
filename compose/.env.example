# ── Auth Mode ─────────────────────────────────────────────────
# Set to "keycloak" or "clerk". Controls which auth provider is
# used by the frontend, backend, and gateway.
#   clerk    → Clerk cloud auth (default, requires API keys below)
#   keycloak → Self-hosted Keycloak (starts automatically)
AUTH_MODE=clerk

# ── Infrastructure ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app

LS_AWS_ACCESS_KEY_ID=test
LS_AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=docteams-dev

INTERNAL_API_KEY=local-dev-api-key-change-in-production
PORTAL_JWT_SECRET=local-dev-portal-jwt-secret-change-in-production
PORTAL_MAGIC_LINK_SECRET=local-dev-magic-link-secret-change-in-production
INTEGRATION_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── Clerk (AUTH_MODE=clerk) ───────────────────────────────────
# Get keys from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
CLERK_ISSUER_URI=https://your-clerk-instance.clerk.accounts.dev
CLERK_JWK_SET_URI=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Keycloak (AUTH_MODE=keycloak) ─────────────────────────────
# These have sensible defaults — only change if you've customized Keycloak.
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_CLIENT_SECRET=docteams-admin-secret
KEYCLOAK_CLIENT_ID=docteams-web
KEYCLOAK_CLIENT_SECRET=docteams-web-secret
KEYCLOAK_DEFAULT_ORG=
NEXTAUTH_SECRET=local-dev-nextauth-secret-at-least-32-characters-long
