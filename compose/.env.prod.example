# compose/.env.prod.example — copy to .env.prod on the box and fill real values.
# .env.prod is git-ignored. NEVER commit real secrets.

# ── Postgres (container) ──────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=app

# ── MinIO (object storage) ────────────────────────────────────────────
MINIO_ROOT_USER=kazi
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
S3_BUCKET=kazi-dev

# ── Keycloak ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_kc_admin_password
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_gateway_bff_client_secret

# ── Backend secrets ───────────────────────────────────────────────────
INTERNAL_API_KEY=CHANGE_ME_internal_api_key
PORTAL_JWT_SECRET=CHANGE_ME_min_32_byte_secret
PORTAL_MAGIC_LINK_SECRET=CHANGE_ME_min_32_byte_secret
# Must be Base64 of 32 raw bytes — generate with: openssl rand -base64 32
# A 32-character hex string decodes to only 24 bytes and will crash startup.
INTEGRATION_ENCRYPTION_KEY=CHANGE_ME_base64_of_32_raw_bytes
EMAIL_UNSUBSCRIBE_SECRET=CHANGE_ME_secret
EMAIL_SENDER_ADDRESS=noreply@heykazi.com

# ── Caddy basic-auth for the Mailpit UI ───────────────────────────────
# Generate hash: docker run --rm caddy caddy hash-password --plaintext 'yourpass'
# IMPORTANT: the bcrypt hash contains '$' chars and docker-compose interpolates
# '$'. You MUST escape every '$' as '$$' in this value, or compose mangles the
# hash and Mailpit login always fails. e.g. $2a$14$abc -> $$2a$$14$$abc
MAIL_BASIC_AUTH_USER=admin
MAIL_BASIC_AUTH_HASH=CHANGE_ME_caddy_bcrypt_hash

# ── GHCR image coordinates ────────────────────────────────────────────
IMAGE_OWNER=rakheen-dama
IMAGE_TAG=dev

# ── Backend: JWT placeholder satisfaction ─────────────────────────────
# application-prod.yml references CLERK_* with no default; the keycloak
# profile overrides the ACTUAL token validation. Set these to the Keycloak
# issuer so placeholder resolution succeeds at startup.
CLERK_ISSUER=https://auth-dev.heykazi.com/realms/docteams
CLERK_JWKS_URI=https://auth-dev.heykazi.com/realms/docteams/protocol/openid-connect/certs

# ── Backend: PayFast (subscriptions) — sandbox values for the dev env ──
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=jt7NOE43FZPn
PAYFAST_SANDBOX=true

# ── Backend: public base URLs (used by PayFast notify/return/cancel) ──
HEYKAZI_BASE_URL=https://api-dev.heykazi.com
HEYKAZI_FRONTEND_URL=https://app-dev.heykazi.com
